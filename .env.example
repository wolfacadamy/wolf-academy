# ── Wolf Academy LMS — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.

# Flask secret key (generate a random string for production)
SECRET_KEY=wolf-academy-secret-key-change-me

# Database URI (default: SQLite in project directory)
DATABASE_URI=sqlite:///lms.db

# SMTP settings for sending email invites
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Base URL for email links (no trailing slash)
BASE_URL=http://127.0.0.1:5000
